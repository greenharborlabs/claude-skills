# Track only agents/, skills/, and Codex skill definitions — ignore everything else
/*
!.gitignore
!agents/
!skills/
!codex/
codex/*
!codex/skills/
!codex/skills/**

# Inside codex/skills: ignore gstack-managed symlinks
codex/skills/gstack
codex/skills/gstack-*

# Inside skills: ignore symlinks (managed in their own repos)
skills/domain-name-brainstormer
skills/skill-creator

# Inside skills: ignore local settings and memory
skills/.claude/
skills/**/memory/
